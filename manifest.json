{
  "manifest_version": 3,
  "name": "Figma Capture",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Capture to Figma",
    "default_popup": "popup.html"
  }
}
